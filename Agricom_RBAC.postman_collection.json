{
  "info": {
    "name": "Agricom CRM – RBAC API",
    "_postman_id": "agricom-rbac-collection",
    "description": "Complete Dynamic RBAC endpoints for Agricom CRM NestJS backend.\n\nBase URL: http://localhost:5000/api\n\nWorkflow:\n1. Login as Super Admin → copy accessToken\n2. Set `token` variable in the collection\n3. Use RBAC endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login (Super Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('token', res.accessToken);",
                  "  console.log('✅ Token saved:', res.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@agricom.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "🏷️ Roles",
      "item": [
        {
          "name": "GetRoles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/GetRoles", "host": ["{{base_url}}"], "path": ["GetRoles"] }
          }
        },
        {
          "name": "GetRoleById",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/GetRoleById?id=1",
              "host": ["{{base_url}}"],
              "path": ["GetRoleById"],
              "query": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "CreateRole",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Manager\",\n  \"description\": \"Manages day-to-day operations\"\n}"
            },
            "url": { "raw": "{{base_url}}/CreateRole", "host": ["{{base_url}}"], "path": ["CreateRole"] }
          }
        },
        {
          "name": "UpdateRole",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 2,\n  \"name\": \"Senior Manager\",\n  \"description\": \"Updated description\",\n  \"isActive\": true\n}"
            },
            "url": { "raw": "{{base_url}}/UpdateRole", "host": ["{{base_url}}"], "path": ["UpdateRole"] }
          }
        },
        {
          "name": "DeleteRole",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/DeleteRole", "host": ["{{base_url}}"], "path": ["DeleteRole"] }
          }
        }
      ]
    },
    {
      "name": "🔑 Permissions",
      "item": [
        {
          "name": "GetPermissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/GetPermissions", "host": ["{{base_url}}"], "path": ["GetPermissions"] }
          }
        },
        {
          "name": "GetPermissionById",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/GetPermissionById?id=1",
              "host": ["{{base_url}}"],
              "path": ["GetPermissionById"],
              "query": [{ "key": "id", "value": "1" }]
            }
          }
        },
        {
          "name": "CreatePermission",
