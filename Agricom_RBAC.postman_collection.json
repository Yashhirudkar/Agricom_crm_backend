            }
          }
        },
        {
          "name": "AssignRoleToUser",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"roleId\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/AssignRoleToUser", "host": ["{{base_url}}"], "path": ["AssignRoleToUser"] }
          }
        },
        {
          "name": "RemoveRoleFromUser",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"roleId\": 2\n}"
            },
            "url": { "raw": "{{base_url}}/RemoveRoleFromUser", "host": ["{{base_url}}"], "path": ["RemoveRoleFromUser"] }
          }
        }
      ]
    },
    {
      "name": "✉️ User Invitations",
      "item": [
        {
          "name": "CreateInvitation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"invitee@clienta.com\",\n  \"roleId\": 2,\n  \"companyIds\": [1, 2]\n}"
            },
            "url": { "raw": "{{base_url}}/invitations/CreateInvitation", "host": ["{{base_url}}"], "path": ["invitations", "CreateInvitation"] }
          }
        },
        {
          "name": "GetInvitations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/invitations", "host": ["{{base_url}}"], "path": ["invitations"] }
          }
        },
        {
          "name": "VerifyInvitation",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/invitations/verify?token=XYZ",
              "host": ["{{base_url}}"],
              "path": ["invitations", "verify"],
              "query": [{ "key": "token", "value": "XYZ" }]
            }
          }
        },
        {
          "name": "AcceptInvitation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"XYZ\",\n  \"name\": \"Invited User\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/invitations/accept", "host": ["{{base_url}}"], "path": ["invitations", "accept"] }
          }
        }
      ]
    },
    {
      "name": "📝 Audit Logs",
      "item": [
        {
          "name": "Get Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/audit/logs?clientId=1", "host": ["{{base_url}}"], "path": ["audit", "logs"], "query": [{ "key": "clientId", "value": "1" }] }
          }
        }
      ]
    },
    {
      "name": "🔔 Notifications",
      "item": [
        {
          "name": "Create Notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 2,\n  \"title\": \"Alert\",\n  \"message\": \"Task assigned to you\",\n  \"type\": \"INFO\"\n}"
            },
            "url": { "raw": "{{base_url}}/notifications", "host": ["{{base_url}}"], "path": ["notifications"] }
          }
        },
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
