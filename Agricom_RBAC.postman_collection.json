            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/GetRolePermissions?roleId=1",
              "host": ["{{base_url}}"],
              "path": ["GetRolePermissions"],
