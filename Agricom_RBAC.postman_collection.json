            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"products:create\",\n  \"resource\": \"products\",\n  \"action\": \"create\",\n  \"description\": \"Allows creating products\"\n}"
            },
            "url": { "raw": "{{base_url}}/CreatePermission", "host": ["{{base_url}}"], "path": ["CreatePermission"] }
          }
        },
        {
          "name": "UpdatePermission",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 12,\n  \"description\": \"Updated description for this permission\",\n  \"isActive\": true\n}"
            },
            "url": { "raw": "{{base_url}}/UpdatePermission", "host": ["{{base_url}}"], "path": ["UpdatePermission"] }
          }
        },
        {
          "name": "DeletePermission",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 12\n}"
            },
            "url": { "raw": "{{base_url}}/DeletePermission", "host": ["{{base_url}}"], "path": ["DeletePermission"] }
          }
        }
      ]
    },
    {
      "name": "🔗 Role ↔ Permission",
      "item": [
        {
          "name": "GetRolePermissions",
          "request": {
