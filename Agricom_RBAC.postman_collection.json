            "url": { "raw": "{{base_url}}/AssignPermissionToRole", "host": ["{{base_url}}"], "path": ["AssignPermissionToRole"] }
          }
        },
        {
          "name": "RemovePermissionFromRole",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleId\": 2,\n  \"permissionId\": 12\n}"
            },
            "url": { "raw": "{{base_url}}/RemovePermissionFromRole", "host": ["{{base_url}}"], "path": ["RemovePermissionFromRole"] }
          }
        }
      ]
    },
    {
      "name": "👤 User ↔ Role",
      "item": [
        {
          "name": "GetUserRoles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/GetUserRoles?userId=1",
              "host": ["{{base_url}}"],
              "path": ["GetUserRoles"],
